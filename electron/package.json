{
  "name": "manuscript-desktop",
  "version": "1.0.0",
  "private": true,
  "description": "ManuScript desktop shell (Electron) for Linux/Ubuntu",
  "main": "main.js",
  "author": "Majeed Baloch",
  "homepage": "https://github.com/writing-editor/NotesApp",
  "scripts": {
    "start": "electron .",
    "dist:linux": "electron-builder --linux deb AppImage"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.majeedbaloch.manuscript",
    "productName": "ManuScript",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../AppCode",
        "to": "AppCode",
        "filter": [
          "**/*",
          "!editor-src",
          "!node_modules/.cache"
        ]
      },
      {
        "from": "../book",
        "to": "book"
      }
    ],
    "linux": {
      "target": [
        { "target": "deb", "arch": ["x64"] },
        { "target": "AppImage", "arch": ["x64"] }
      ],
      "category": "Office",
      "icon": "build-resources/icon.png",
      "executableName": "manuscript",
      "synopsis": "Markdown manuscript reader and margin-note editor",
      "maintainer": "Majeed Baloch"
    },
    "deb": {
      "depends": [
        "libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ]
    }
  }
}